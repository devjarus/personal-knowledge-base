{
  "name": "personal-knowledge-base",
  "version": "0.1.0",
  "private": true,
  "description": "Personal knowledge base — local markdown + S3 sync + MCP + CLI + web UI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devjarus/personal-knowledge-base.git"
  },
  "bugs": {
    "url": "https://github.com/devjarus/personal-knowledge-base/issues"
  },
  "homepage": "https://github.com/devjarus/personal-knowledge-base#readme",
  "keywords": [
    "knowledge-base",
    "markdown",
    "notes",
    "mcp",
    "cli",
    "s3",
    "nextjs",
    "local-first"
  ],
  "bin": {
    "kb": "./bin/kb.mjs",
    "kb-mcp": "./bin/mcp.mjs"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "kb": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.687.0",
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "^15.1.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
