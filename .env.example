# Where your knowledge lives on disk. Defaults to ./kb relative to the repo.
# Set this to somewhere stable (e.g. ~/Documents/kb) if you want the KB to
# survive across repo clones.
KB_ROOT=./kb

# --- S3 sync (optional) ---
# Only needed if you run `pnpm kb sync`. Leave blank to disable sync entirely.
KB_S3_BUCKET=
KB_S3_PREFIX=kb/
AWS_REGION=us-east-1
# Use standard AWS credential resolution (env vars, ~/.aws/credentials, SSO, etc.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
