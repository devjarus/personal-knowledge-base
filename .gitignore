# Coding-agent pipeline workspace (local only)
.coding-agent/

# Playwright MCP scratch dir (screenshots, traces)
.playwright-mcp/

# KB content — tracked seed files (welcome.md, README.md) stay tracked
# because git honors explicit history over .gitignore. But anything else
# written into kb/ (including imports/) stays local-only. Your real KB
# lives at $KB_ROOT outside the repo.
kb/

# Semantic index sidecar — generated artifact, never commit.
# The .kb-index/ directory lives inside the KB root (wherever KB_ROOT points).
# If you track your KB in git, add a similar rule in that repo's .gitignore.
**/.kb-index/
